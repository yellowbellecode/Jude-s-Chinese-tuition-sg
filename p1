                    </div>
                    <div class="progress-bar-bg">
                        <div class="progress-bar-fill" style="width: 50%"></div>
                    </div>
                </div>
                <div class="lesson-actions">
                    <a href="#" class="btn btn-primary">▶️ Continue</a>
                    <a href="#" class="btn btn-outline">✍️ Practice</a>
                </div>
            </div>

            <!-- Lesson 3 - Not Started -->
            <div class="lesson-card not-started">
                <div class="lesson-header">
                    <h3>Lesson 3: Numbers 数字</h3>
                    <span class="status-badge not-started">⭕ Not Started</span>
                </div>
                <div class="vocab-preview">
                    <span>一</span> <span>二</span> <span>三</span> <span>四</span> <span>五</span>
                </div>
                <div class="lesson-progress">
                    <div class="progress-text">
                        <span>Mastered: 0/5 words</span>
                        <span>0%</span>
                    </div>
                    <div class="progress-bar-bg">
                        <div class="progress-bar-fill" style="width: 0%"></div>
                    </div>
                </div>
                <div class="lesson-actions">
                    <a href="#" class="btn btn-primary">▶️ Start Lesson</a>
                </div>
            </div>

            <!-- Lesson 4 - Not Started -->
            <div class="lesson-card not-started">
                <div class="lesson-header">
                    <h3>Lesson 4: Colors 颜色</h3>
                    <span class="status-badge not-started">⭕ Not Started</span>
                </div>
                <div class="vocab-preview">
                    <span>红色</span> <span>蓝色</span> <span>黄色</span> <span>绿色</span>
                </div>
                <div class="lesson-progress">
                    <div class="progress-text">
                        <span>Mastered: 0/4 words</span>
                        <span>0%</span>
                    </div>
                    <div class="progress-bar-bg">
                        <div class="progress-bar-fill" style="width: 0%"></div>
                    </div>
                </div>
                <div class="lesson-actions">
                    <a href="#" class="btn btn-primary">▶️ Start Lesson</a>
                </div>
            </div>
        </div>

        <!-- Tests Section -->
        <h2 class="section-title">📝 Lesson Tests</h2>
        <div class="tests-grid">
            <div class="test-card">
                <h3>Lesson 1 Test: Family</h3>
                <div class="test-score">85%</div>
                <p>Last taken: Today</p>
                <a href="#" class="btn btn-outline">Retake Test</a>
            </div>
            <div class="test-card">
                <h3>Lesson 2 Test: School</h3>
                <div class="test-score">—</div>
                <p>Not taken yet</p>
                <a href="#" class="btn btn-primary">Take Test</a>
            </div>
        </div>

        <!-- Words to Review -->
        <div style="background: white; border-radius: 15px; padding: 1.5rem; margin: 2rem 0;">
            <h3>🔤 Words to Review</h3>
            <div style="display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 1rem;">
                <span style="background: #f8d7da; padding: 0.5rem 1rem; border-radius: 20px;">老师 <span style="color: #721c24;">(2 mistakes)</span></span>
                <span style="background: #fff3cd; padding: 0.5rem 1rem; border-radius: 20px;">同学 <span style="color: #856404;">(1 mistake)</span></span>
            </div>
        </div>
    </div>

    <footer>
        <p>© 2024 Jude's Chinese Learning Journey. Following MOE Syllabus.</p>
    </footer>
</body>
</html>
